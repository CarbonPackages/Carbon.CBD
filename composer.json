{
    "name": "carbon/cbd",
    "type": "neos-carbon",
    "description": "Make complex content structure (e.g. slider, maps, etc.) easily editable in Neos. Fast and bullet-proof",
    "license": "GPL-3.0",
    "keywords": [
        "flow",
        "neos",
        "fusion",
        "helper",
        "carbon",
        "backend"
    ],
    "require": {
        "neos/neos": "^8.4",
        "carbon/eel": "^2.14"
    },
    "authors": [
        {
            "name": "Jon Uhlmann",
            "email": "hello@uhlmann.pro",
            "homepage": "https://uhlmann.pro",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Carbon\\CBD\\": "Classes"
        }
    },
    "extra": {
        "installer-name": "Carbon.CBD",
        "neos": {
            "package-key": "Carbon.CBD"
        }
    }
}
